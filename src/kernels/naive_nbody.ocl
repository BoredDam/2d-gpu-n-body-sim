#define EPSILON 5.0f
#define G 0.2f


kernel void update_acc(
    global const float2 *body_pos,
    global float2 *body_acc,
    global const float *body_mass,
    int body_count
) {
    int id = get_global_id(0);

    if (id >= body_count) {
        return;
    }

    const float2 this_pos = body_pos[id];
    float2 this_acc = (float2)(0.0f, 0.0f);

    for (int i = 0; i < body_count; i++) {
        if (i == id) {
            continue;
        }

        const float2 dist_vec = body_pos[i] - this_pos;
        const float dist_squared = fmax(dot(dist_vec, dist_vec), EPSILON);
        const float inv_dist = rsqrt(dist_squared);
        const float inv_dist3 = inv_dist * inv_dist * inv_dist;

        this_acc += G * body_mass[i] * dist_vec * inv_dist3;
    }

    body_acc[id] = this_acc;
}

