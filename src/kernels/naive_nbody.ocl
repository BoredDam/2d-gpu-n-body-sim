kernel void update_vel(
    global float2 *body_vel,
    global float2 *body_acc,
    float delta_time,
    int body_count
) {

    int id = get_global_id(0);

    if (id >= body_count) {
        return;
    }

    body_vel[id] += body_acc[id] * delta_time;
}


kernel void update_pos(
    global float2 *body_pos,
    global float2 *body_vel,
    float delta_time,
    int body_count
) {
    int id = get_global_id(0);

    if (id >= body_count) {
        return;
    }

    body_pos[id] += body_vel[id] * delta_time;
}

